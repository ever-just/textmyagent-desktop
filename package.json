{
  "name": "textmyagent-desktop",
  "version": "1.7.0",
  "description": "AI Assistant for iMessage - Desktop App",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:dashboard\" \"npm run dev:electron\"",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:electron": "tsc -p electron/tsconfig.json && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "npm run build:dashboard && npm run build:electron",
    "build:dashboard": "cd dashboard && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "electron-updater": "^6.1.8",
    "express": "^4.18.2",
    "node-mac-contacts": "^1.7.2"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "electron": "^39.8.6",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.2"
  },
  "author": "Weldon Makori",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ever-just/textmyagent-desktop.git"
  }
}
